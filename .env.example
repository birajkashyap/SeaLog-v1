# Environment variables for SeaLog

# Database Configuration
DATABASE_URL="postgresql://sealog_user:sealog_password@localhost:5432/sealog?schema=public"
# Optional, development only: admin/owner connection used by simulate-tamper demo endpoint
TAMPER_DATABASE_URL=""

# Blockchain Configuration
BLOCKCHAIN_NETWORK="sepolia"
BLOCKCHAIN_RPC_URL="https://sepolia.infura.io/v3/YOUR_INFURA_KEY"
BLOCKCHAIN_PRIVATE_KEY="your_private_key_here"
CONTRACT_ADDRESS=""

# API Configuration
API_PORT=3000
API_HOST="localhost"

# Batch Processing Configuration
BATCH_STRATEGY="hybrid"
BATCH_TIME_INTERVAL_SECONDS=300
BATCH_SIZE_THRESHOLD=10000

# Logging
LOG_LEVEL="info"
